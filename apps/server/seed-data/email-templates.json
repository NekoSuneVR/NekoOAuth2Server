    "content": "<!DOCTYPE html>\n<html lang=\"en\" xmlns=\"http://www.w3.org/1999/xhtml\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<meta name=\"x-apple-disable-message-reformatting\">\n<title>Two-step verification</title>\n<style>\n@media only screen and (max-width:600px){.container{width:100%!important}.px{padding-left:20px!important;padding-right:20px!important}.codebox{font-size:28px!important;letter-spacing:6px!important}}\n</style>\n</head>\n<body style=\"margin:0;padding:0;background-color:#f4f4f7;-webkit-text-size-adjust:100%;\">\n<div style=\"display:none;max-height:0;overflow:hidden;opacity:0;color:transparent;height:0;width:0;\">Your MFA verification code (valid for 10 minutes)</div>\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#f4f4f7;\">\n<tr><td align=\"center\" style=\"padding:32px 16px;\">\n<table role=\"presentation\" class=\"container\" width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"width:600px;max-width:600px;background-color:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #eceef1;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;\">\n<tr><td style=\"background-color:#6d28d9;padding:22px 28px;\"><span style=\"color:#ffffff;font-size:17px;font-weight:500;letter-spacing:0.3px;\">NekoSuneVR</span></td></tr>\n<tr><td class=\"px\" style=\"padding:32px 28px 4px 28px;\">\n<h1 style=\"margin:0 0 10px 0;font-size:21px;line-height:1.3;color:#111827;font-weight:500;\">Two-step verification</h1>\n<p style=\"margin:0 0 22px 0;font-size:15px;line-height:1.6;color:#4b5563;\">Use the code below to complete two-step verification.</p>\n</td></tr>\n<tr><td class=\"px\" style=\"padding:0 28px;\">\n<table role=\"presentation\" width=\"100%\" cellpadding=\"0\" cellspacing=\"0\"><tr>\n<td align=\"center\" style=\"background-color:#f5f3ff;border:1px solid #e9e5ff;border-radius:10px;padding:20px 12px;\">\n<div class=\"codebox\" style=\"font-family:'SFMono-Regular',Consolas,Menlo,monospace;font-size:32px;font-weight:500;letter-spacing:8px;color:#5b21b6;\">{{code}}</div>\n</td></tr></table>\n</td></tr>\n<tr><td class=\"px\" style=\"padding:16px 28px 0 28px;\">\n<p style=\"margin:0;font-size:13px;line-height:1.6;color:#6b7280;\">This code stays active for <span style=\"color:#374151;font-weight:500;\">10 minutes</span>. For your security, don't share it with anyone.</p>\n</td></tr>\n<tr><td class=\"px\" style=\"padding:22px 28px 28px 28px;\">\n<div style=\"border-top:1px solid #eceef1;font-size:1px;line-height:1px;margin:0 0 14px 0;\">&nbsp;</div>\n<p style=\"margin:0;font-size:12px;line-height:1.6;color:#9ca3af;\">If you didn't request this, you can safely ignore this email &mdash; no action is needed.</p>\n<p style=\"margin:10px 0 0 0;font-size:12px;line-height:1.6;color:#9ca3af;\">Sent by NekoSuneVR &middot; oauth2.nekosunevr.co.uk</p>\n</td></tr>\n</table>\n</td></tr>\n</table>\n</body>\n</html>",
