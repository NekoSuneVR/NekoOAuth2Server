# apps/server
PORT=4000
NODE_ENV=development

# Matches docker-compose.dev.yml's Postgres service
DATABASE_URL=postgresql://nekooauth2server:nekooauth2server@localhost:5432/nekooauth2server

# oidc-provider
ISSUER=http://localhost:4000/oidc

# Generate with `pnpm --filter server generate:jwks`. Required for issued
# tokens/sessions to survive a server restart — left unset, oidc-provider
# falls back to an ephemeral dev keystore regenerated every restart.
# JWKS=

# Upstream connectors (Phase 4) — each is only enabled if BOTH its client id
# and secret are set. Leave unset to boot without that "Sign in with X" option.
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# ROBLOX_CLIENT_ID=
# ROBLOX_CLIENT_SECRET=
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
# VPZONE_CLIENT_ID=
# VPZONE_CLIENT_SECRET=

# VRChat bot (Phase 4) — a real bot account; all three must be set for it to
# log in. Not live-tested (no real VRChat bot account in this environment).
# VRCHAT_BOT_USERNAME=
# VRCHAT_BOT_PASSWORD=
# VRCHAT_BOT_TOTP_SECRET=
