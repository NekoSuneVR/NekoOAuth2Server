generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Application data model (see TODO.md Phase 0's "shared identity" decision) ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

// A downstream Neko* project's registered OAuth2 application.
// oidc-provider's own "Client" adapter model is backed by this table
// (see src/oidc/adapter.ts), not by the generic OidcModel table below —
// this is the source of truth an admin console CRUDs against directly.
model Client {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  name     String
  clientId String @unique
  // Stored in plaintext deliberately, not hashed: oidc-provider's built-in
  // client_secret_basic/client_secret_post verification does a constant-time
  // comparison against the raw configured secret, so a one-way hash would
  // break auth outright. Phase 9 (Security Hardening) should revisit this as
  // reversible envelope encryption at rest, not hashing.
  clientSecret   String?
  isConfidential Boolean @default(true)
  redirectUris          String[]
  grantTypes            String[] @default(["authorization_code", "refresh_token"])
  responseTypes         String[] @default(["code"])
  scope                 String   @default("openid profile email")
  tokenEndpointAuthMethod String @default("client_secret_basic")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  consents ClientConsent[]
  roles    Role[]
  webhookEndpoints WebhookEndpoint[]
}

// A downstream app registers a URL here to be notified of account lifecycle
// events for users it has a relationship with (see ClientConsent) — Phase 5's
// deletion cascade is the first real use, more events can follow later
// without a schema change (the payload's `event` field just changes).
model WebhookEndpoint {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  url       String
  // HMAC secret for the X-Neko-Signature header — lets the receiving app
  // verify a delivery actually came from us. Rotatable via the admin API
  // (Phase 9) without re-registering the endpoint.
  secret    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]
}

// A log of what we actually sent and what happened — Phase 9's "delivery
// log"/hardening starts from this, not from scratch. `attempt` distinguishes
// a retried redelivery (Phase 9's retry/backoff) from the original attempt.
// `payload` is the exact JSON body sent, kept specifically so the admin
// console's "resend" action can replay the identical signed payload rather
// than trying to reconstruct one.
model WebhookDelivery {
  id                String          @id @default(cuid())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id])
  event             String
  payload           Json?
  attempt           Int             @default(1)
  statusCode        Int?
  error             String?
  deliveredAt       DateTime        @default(now())
}

// A role belongs to exactly one Client, not a Tenant — see TODO.md Phase 3's
// tenant-isolation decision. "admin in Project A" and "admin in Project B"
// are deliberately different Role rows, even with the same name, so a role
// assignment can never leak permissions across projects.
model Role {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]

  @@unique([clientId, name])
}

model UserRole {
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id            String     @id @default(cuid())
  primaryEmail  String?    @unique
  emailVerified Boolean    @default(false)
  // Minimal baseline credential so the OIDC interaction flow (Phase 2) has
  // *some* real way to authenticate a user before any upstream connector
  // (Phase 4) or email/SMTP flow (Phase 6) exists. Nullable: a user who only
  // ever signs in via a social connector or VRChat's bot-verified flow may
  // never set one. Whether email+password stays the primary end-user login
  // method long-term, vs. magic links/WebAuthn/social-only, is still an open
  // question — see TODO.md.
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  linkedIdentities LinkedIdentity[]
  consents         ClientConsent[]
  userRoles        UserRole[]
}

// One row per external platform linked to a User. `verifiedVia` distinguishes
// standard OAuth2/OIDC connectors from VRChat's bot-verified bio/friend-request
// flow (see TODO.md Phase 4).
model LinkedIdentity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  provider          String
  providerUserId    String
  providerUsername  String?
  verifiedVia       String
  linkedAt          DateTime @default(now())

  @@unique([provider, providerUserId])
}

// Which scopes a User has granted a given Client — the source of truth for
// "what can a downstream app read" (TODO.md Phase 0).
model ClientConsent {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  grantedScopes String[]
  grantedAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@unique([userId, clientId])
}

// --- Transactional email (see TODO.md Phase 6) ---

// Singleton row (fixed id "default") — admin-configurable SMTP settings.
// v1 is SMTP-only; a pluggable EmailSender interface (src/email/types.ts)
// means a SendGrid/Mailgun/HTTP-based sender can be added later without a
// schema redesign, just a different implementation behind the same seam.
model SmtpConfig {
  id          String   @id
  host        String
  port        Int
  secure      Boolean  @default(false)
  username    String?
  // Stored in plaintext deliberately — same at-rest tradeoff already made for
  // Client.clientSecret above (oidc-provider's own comparison needs the raw
  // value there; here it's simply not built yet). Phase 9 should revisit both
  // as reversible envelope encryption, not hashing.
  password    String?
  fromAddress String
  fromName    String?
  updatedAt   DateTime @updatedAt
}

// One row per `usageType`, matching Logto's email-connector template model
// exactly (see TODO.md Phase 0 research notes). Seeded from
// seed-data/email-templates.json; editable via the admin API in
// src/email/templatesApi.ts (no console UI yet — see Phase 6/8 notes).
model EmailTemplate {
  id          String   @id @default(cuid())
  usageType   String   @unique
  subject     String
  content     String
  contentType String   @default("text/html")
  updatedAt   DateTime @updatedAt
}

// A log of every send attempt (sent or not, and why) — doubles as the data
// source for the per-address rate limit in src/email/sendEmail.ts and as the
// starting point for Phase 9's audit log, not a separate thing to build later.
model EmailLog {
  id        String   @id @default(cuid())
  usageType String
  toAddress String
  success   Boolean
  error     String?
  sentAt    DateTime @default(now())

  @@index([toAddress, sentAt])
}

// --- Security hardening & audit logging (see TODO.md Phase 9) ---

// One row per login, token issuance/revocation, and admin action — real
// coverage, not every single internal oidc-provider state transition (see
// src/audit/log.ts's doc comment for exactly what's wired up and why).
// `metadata` is deliberately never allowed to contain a raw secret — the
// audit log itself must never become a way to leak one.
model AuditLogEntry {
  id            String   @id @default(cuid())
  event         String
  actorUserId   String?
  actorClientId String?
  targetType    String?
  targetId      String?
  metadata      Json?
  ipAddress     String?
  createdAt     DateTime @default(now())

  @@index([event, createdAt])
  @@index([actorUserId, createdAt])
}

// DB-backed upstream connector configuration (Phase 8/9) — replaces Phase 4's
// env-var-only setup so the admin console can manage connectors without a
// server restart. `presetId` (e.g. "discord") points at a known named
// preset's endpoint template in src/connectors/presets.ts; a row with no
// `presetId` is a fully custom OAuth2/OIDC connector, using its own
// endpoint/issuer columns instead. Existing env-var-configured deployments
// are migrated once, automatically, on first boot after this shipped (see
// src/connectors/registry.ts's `migrateEnvConnectorsIfEmpty`), not silently
// abandoned.
model Connector {
  id                    String   @id @default(cuid())
  providerId            String   @unique
  displayName           String
  presetId              String?
  type                  String // "oauth2" | "oidc"
  clientId              String
  // Encrypted at rest (see src/security/encryption.ts) — decrypted only
  // in-memory when building the live connector registry.
  clientSecret          String
  authorizationEndpoint String?
  tokenEndpoint         String?
  userInfoEndpoint      String?
  issuer                String?
  scope                 String
  pkce                  String // "required" | "optional" | "unsupported"
  enabled               Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// --- oidc-provider storage adapter ---
//
// Generic key/value-style table backing every oidc-provider model EXCEPT
// "Client" (which reads from the Client table above instead). One row per
// grant/token/session/etc. instance, namespaced by `type` (the oidc-provider
// model name, e.g. "AccessToken", "AuthorizationCode", "Session", "Grant").
// This mirrors the standard community pattern for SQL-backed oidc-provider
// adapters rather than defining one bespoke table per model type.
model OidcModel {
  type      String
  id        String
  payload   Json
  grantId   String?
  userCode  String?
  uid       String?
  expiresAt DateTime?

  @@id([type, id])
  @@index([type, grantId])
  @@unique([type, userCode])
  @@unique([type, uid])
}
