# Copy to .env.local for local dev.

# Matches the "neko-console" Client seeded by apps/server's prisma/seed.ts.
NEKO_OAUTH_ISSUER=http://localhost:4000/oidc
NEKO_OAUTH_CLIENT_ID=neko-console
NEKO_OAUTH_CLIENT_SECRET=neko-console-dev-secret

# Base URL apps/server's admin API is reachable at (server-side fetches only —
# never exposed to the browser).
NEKO_SERVER_URL=http://localhost:4000

# NextAuth/Auth.js requirements. Generate a real AUTH_SECRET for anything
# beyond local dev: `npx auth secret` or `openssl rand -base64 32`.
AUTH_SECRET=dev-insecure-auth-secret-change-me
AUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true
