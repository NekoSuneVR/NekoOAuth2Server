{
  "name": "@nekosunevr/oauth2-sdk",
  "version": "0.1.0",
  "description": "Client SDK for logging into NekoOAuth2Server (OIDC/OAuth 2.1) — PKCE, token exchange, id_token verification, and an Express middleware helper.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/express.d.ts",
      "default": "./dist/express.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NekoSuneVR/NekoOAuth2Server.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/NekoSuneVR/NekoOAuth2Server/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/NekoSuneVR/NekoOAuth2Server/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo \"no lint configured\" && exit 0"
  },
  "dependencies": {
    "jose": "^5.9.6"
  },
  "peerDependencies": {
    "express": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.2",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "server": "workspace:*",
    "supertest": "^7.0.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
