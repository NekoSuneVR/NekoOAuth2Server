generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Application data model (see TODO.md Phase 0's "shared identity" decision) ---

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients Client[]
}

// A downstream Neko* project's registered OAuth2 application.
// oidc-provider's own "Client" adapter model is backed by this table
// (see src/oidc/adapter.ts), not by the generic OidcModel table below —
// this is the source of truth an admin console CRUDs against directly.
model Client {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  name     String
  clientId String @unique
  // Stored in plaintext deliberately, not hashed: oidc-provider's built-in
  // client_secret_basic/client_secret_post verification does a constant-time
  // comparison against the raw configured secret, so a one-way hash would
  // break auth outright. Phase 9 (Security Hardening) should revisit this as
  // reversible envelope encryption at rest, not hashing.
  clientSecret   String?
  isConfidential Boolean @default(true)
  redirectUris          String[]
  grantTypes            String[] @default(["authorization_code", "refresh_token"])
  responseTypes         String[] @default(["code"])
  scope                 String   @default("openid profile email")
  tokenEndpointAuthMethod String @default("client_secret_basic")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  consents ClientConsent[]
  roles    Role[]
  webhookEndpoints WebhookEndpoint[]
}

// A downstream app registers a URL here to be notified of account lifecycle
// events for users it has a relationship with (see ClientConsent) — Phase 5's
// deletion cascade is the first real use, more events can follow later
// without a schema change (the payload's `event` field just changes).
model WebhookEndpoint {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  url       String
  // HMAC secret for the X-Neko-Signature header — lets the receiving app
  // verify a delivery actually came from us. Phase 9 should revisit rotation.
  secret    String
  createdAt DateTime @default(now())

  deliveries WebhookDelivery[]
}

// A log of what we actually sent and what happened — Phase 9's "delivery
// log"/hardening starts from this, not from scratch.
model WebhookDelivery {
  id                String          @id @default(cuid())
  webhookEndpointId String
  webhookEndpoint   WebhookEndpoint @relation(fields: [webhookEndpointId], references: [id])
  event             String
  statusCode        Int?
  error             String?
  deliveredAt       DateTime        @default(now())
}

// A role belongs to exactly one Client, not a Tenant — see TODO.md Phase 3's
// tenant-isolation decision. "admin in Project A" and "admin in Project B"
// are deliberately different Role rows, even with the same name, so a role
// assignment can never leak permissions across projects.
model Role {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  name        String
  description String?
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]

  @@unique([clientId, name])
}

model UserRole {
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now())

  @@id([userId, roleId])
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model User {
  id            String     @id @default(cuid())
  primaryEmail  String?    @unique
  emailVerified Boolean    @default(false)
  // Minimal baseline credential so the OIDC interaction flow (Phase 2) has
  // *some* real way to authenticate a user before any upstream connector
  // (Phase 4) or email/SMTP flow (Phase 6) exists. Nullable: a user who only
  // ever signs in via a social connector or VRChat's bot-verified flow may
  // never set one. Whether email+password stays the primary end-user login
  // method long-term, vs. magic links/WebAuthn/social-only, is still an open
  // question — see TODO.md.
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  status        UserStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  linkedIdentities LinkedIdentity[]
  consents         ClientConsent[]
  userRoles        UserRole[]
}

// One row per external platform linked to a User. `verifiedVia` distinguishes
// standard OAuth2/OIDC connectors from VRChat's bot-verified bio/friend-request
// flow (see TODO.md Phase 4).
model LinkedIdentity {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  provider          String
  providerUserId    String
  providerUsername  String?
  verifiedVia       String
  linkedAt          DateTime @default(now())

  @@unique([provider, providerUserId])
}

// Which scopes a User has granted a given Client — the source of truth for
// "what can a downstream app read" (TODO.md Phase 0).
model ClientConsent {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  grantedScopes String[]
  grantedAt     DateTime  @default(now())
  revokedAt     DateTime?

  @@unique([userId, clientId])
}

// --- oidc-provider storage adapter ---
//
// Generic key/value-style table backing every oidc-provider model EXCEPT
// "Client" (which reads from the Client table above instead). One row per
// grant/token/session/etc. instance, namespaced by `type` (the oidc-provider
// model name, e.g. "AccessToken", "AuthorizationCode", "Session", "Grant").
// This mirrors the standard community pattern for SQL-backed oidc-provider
// adapters rather than defining one bespoke table per model type.
model OidcModel {
  type      String
  id        String
  payload   Json
  grantId   String?
  userCode  String?
  uid       String?
  expiresAt DateTime?

  @@id([type, id])
  @@index([type, grantId])
  @@unique([type, userCode])
  @@unique([type, uid])
}
