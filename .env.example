# apps/server
PORT=4000
NODE_ENV=development

# Matches docker-compose.dev.yml's Postgres service
DATABASE_URL=postgresql://nekooauth2server:nekooauth2server@localhost:5432/nekooauth2server

# oidc-provider
ISSUER=http://localhost:4000/oidc

# Generate with `pnpm --filter server generate:jwks`. Required for issued
# tokens/sessions to survive a server restart — left unset, oidc-provider
# falls back to an ephemeral dev keystore regenerated every restart.
# JWKS=
